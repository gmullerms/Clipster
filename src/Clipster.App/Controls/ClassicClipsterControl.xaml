<UserControl x:Class="Clipster.App.Controls.ClassicClipsterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="80" Height="120"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <SineEase x:Key="SineEase" EasingMode="EaseInOut"/>

        <!-- Idle: subtle sway -->
        <Storyboard x:Key="IdleAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BodyTransform" Storyboard.TargetProperty="Y"
                             From="0" To="-2" Duration="0:0:2" AutoReverse="True"
                             EasingFunction="{StaticResource SineEase}"/>
            <!-- Blink -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftEyeScale" Storyboard.TargetProperty="ScaleY" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.5" Value="0.1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.65" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:5.0" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightEyeScale" Storyboard.TargetProperty="ScaleY" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.5" Value="0.1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.65" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:5.0" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Thinking: tilt back and forth -->
        <Storyboard x:Key="ThinkingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="-5" To="5" Duration="0:0:1" AutoReverse="True"/>
            <!-- Eyes look up-left -->
            <DoubleAnimation Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="X"
                             To="-2" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="Y"
                             To="-2" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="X"
                             To="-2" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="Y"
                             To="-2" Duration="0:0:0.3"/>
        </Storyboard>

        <!-- Greeting: quick hop and lean -->
        <Storyboard x:Key="GreetingAnimation">
            <DoubleAnimation Storyboard.TargetName="BodyTransform" Storyboard.TargetProperty="Y"
                             From="0" To="-12" Duration="0:0:0.2" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="-12" Duration="0:0:0.3" AutoReverse="True"
                             BeginTime="0:0:0.1"/>
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="12" Duration="0:0:0.3" AutoReverse="True"
                             BeginTime="0:0:0.6"/>
        </Storyboard>

        <!-- Talking: nod -->
        <Storyboard x:Key="TalkingAnimation" RepeatBehavior="3x">
            <DoubleAnimation Storyboard.TargetName="BodyTransform" Storyboard.TargetProperty="Y"
                             From="0" To="-4" Duration="0:0:0.2" AutoReverse="True"/>
        </Storyboard>

        <!-- Pointing: lean left -->
        <Storyboard x:Key="PointingAnimation">
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="-15" Duration="0:0:0.3"/>
        </Storyboard>

        <!-- Confused: rapid small wobble -->
        <Storyboard x:Key="ConfusedAnimation" RepeatBehavior="3x">
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="-8" To="8" Duration="0:0:0.15" AutoReverse="True"/>
        </Storyboard>

        <!-- Celebrating: big jump -->
        <Storyboard x:Key="CelebratingAnimation">
            <DoubleAnimation Storyboard.TargetName="BodyTransform" Storyboard.TargetProperty="Y"
                             From="0" To="-20" Duration="0:0:0.3" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:0.6"/>
        </Storyboard>

        <!-- Looking: eyes move -->
        <Storyboard x:Key="LookingAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="X">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.0" Value="-2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="X">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.0" Value="-2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Canvas x:Name="ClipsterCanvas">
        <Canvas x:Name="ClipsterBody" Canvas.Left="10" Canvas.Top="10">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <RotateTransform x:Name="BodyRotation" Angle="0" CenterX="30" CenterY="45"/>
                    <TranslateTransform x:Name="BodyTransform" X="0" Y="0"/>
                </TransformGroup>
            </Canvas.RenderTransform>

            <!-- Shadow -->
            <Ellipse Canvas.Left="10" Canvas.Top="86" Width="40" Height="8" Fill="#18000000"/>

            <!-- Classic-style paperclip body (flat color, thicker strokes, no gradients) -->
            <Path Stroke="#FF5B9BD5" StrokeThickness="6" Fill="Transparent"
                  StrokeLineJoin="Miter" StrokeStartLineCap="Square" StrokeEndLineCap="Square"
                  Data="M 22,5 C 10,5 3,18 3,30 L 3,62 C 3,78 14,87 27,87 C 40,87 50,78 50,62 L 50,24 C 50,13 42,5 32,5 C 22,5 16,13 16,24 L 16,57 C 16,65 22,70 30,70 C 38,70 43,65 43,57 L 43,30"/>
            <!-- Highlight (simpler) -->
            <Path Stroke="#80FFFFFF" StrokeThickness="2"
                  StrokeStartLineCap="Square" StrokeEndLineCap="Square"
                  Data="M 10,20 L 10,50" Fill="Transparent"/>

            <!-- Left eye - blockier style -->
            <Rectangle Canvas.Left="18" Canvas.Top="28" Width="10" Height="12"
                       RadiusX="2" RadiusY="2"
                       Fill="White" Stroke="#FF4472C4" StrokeThickness="1.5"/>
            <Ellipse x:Name="LeftPupilClassic" Canvas.Left="21" Canvas.Top="32" Width="5" Height="5" Fill="Black">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="LeftEyeScale" ScaleX="1" ScaleY="1" CenterX="2.5" CenterY="2.5"/>
                        <TranslateTransform x:Name="LeftPupilPos" X="0" Y="0"/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Right eye - blockier style -->
            <Rectangle Canvas.Left="34" Canvas.Top="28" Width="10" Height="12"
                       RadiusX="2" RadiusY="2"
                       Fill="White" Stroke="#FF4472C4" StrokeThickness="1.5"/>
            <Ellipse x:Name="RightPupilClassic" Canvas.Left="37" Canvas.Top="32" Width="5" Height="5" Fill="Black">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="RightEyeScale" ScaleX="1" ScaleY="1" CenterX="2.5" CenterY="2.5"/>
                        <TranslateTransform x:Name="RightPupilPos" X="0" Y="0"/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Thick blocky eyebrows -->
            <Line X1="17" Y1="25" X2="28" Y2="24" Stroke="#FF4472C4" StrokeThickness="3"
                  StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
            <Line X1="34" Y1="24" X2="45" Y2="25" Stroke="#FF4472C4" StrokeThickness="3"
                  StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
        </Canvas>
    </Canvas>
</UserControl>
