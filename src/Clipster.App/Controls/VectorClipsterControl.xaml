<UserControl x:Class="Clipster.App.Controls.VectorClipsterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="120" Height="160">
    <UserControl.Resources>
        <!-- Easing functions -->
        <SineEase x:Key="Sine" EasingMode="EaseInOut"/>
        <BackEase x:Key="Back" EasingMode="EaseOut" Amplitude="0.5"/>
        <BounceEase x:Key="Bounce" EasingMode="EaseOut" Bounces="2" Bounciness="3"/>
        <ElasticEase x:Key="Elastic" EasingMode="EaseOut" Oscillations="1" Springiness="4"/>

        <!-- ============ IDLE: float + breathe + blink + fidget ============ -->
        <Storyboard x:Key="IdleAnimation" RepeatBehavior="Forever">
            <!-- Float up/down -->
            <DoubleAnimation Storyboard.TargetName="BodyPos" Storyboard.TargetProperty="Y"
                             From="0" To="-5" Duration="0:0:2" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <!-- Gentle breathe scale -->
            <DoubleAnimation Storyboard.TargetName="BodyScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.015" Duration="0:0:2.5" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <DoubleAnimation Storyboard.TargetName="BodyScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.02" Duration="0:0:2.5" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <!-- Shadow pulses with float -->
            <DoubleAnimation Storyboard.TargetName="Shadow" Storyboard.TargetProperty="Opacity"
                             From="0.18" To="0.12" Duration="0:0:2" AutoReverse="True"/>
            <!-- Blink every ~4s -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftEyeScale" Storyboard.TargetProperty="ScaleY" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:3.9" Value="1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4.0" Value="0.05"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4.12" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightEyeScale" Storyboard.TargetProperty="ScaleY" RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:3.9" Value="1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4.0" Value="0.05"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4.12" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:7" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Subtle left arm sway -->
            <DoubleAnimation Storyboard.TargetName="LeftArmRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="8" Duration="0:0:3" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <!-- Subtle right arm sway (offset) -->
            <DoubleAnimation Storyboard.TargetName="RightArmRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="-6" Duration="0:0:2.5" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
        </Storyboard>

        <!-- ============ THINKING: tilt + eyes up-left + hand to chin ============ -->
        <Storyboard x:Key="ThinkingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="-6" To="6" Duration="0:0:1.2" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <!-- Eyes look up-left, thinking -->
            <DoubleAnimation Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="X"
                             To="-2" Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="Y"
                             To="-3" Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="X"
                             To="-2" Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="Y"
                             To="-3" Duration="0:0:0.5"/>
            <!-- Right arm up to chin -->
            <DoubleAnimation Storyboard.TargetName="RightArmRotation" Storyboard.TargetProperty="Angle"
                             To="-50" Duration="0:0:0.5" EasingFunction="{StaticResource Back}"/>
            <!-- Raise eyebrows -->
            <DoubleAnimation Storyboard.TargetName="LeftBrowPos" Storyboard.TargetProperty="Y"
                             To="-3" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RightBrowPos" Storyboard.TargetProperty="Y"
                             To="-3" Duration="0:0:0.4"/>
        </Storyboard>

        <!-- ============ GREETING: big wave ============ -->
        <Storyboard x:Key="GreetingAnimation">
            <!-- Bounce up -->
            <DoubleAnimation Storyboard.TargetName="BodyPos" Storyboard.TargetProperty="Y"
                             From="0" To="-18" Duration="0:0:0.35" AutoReverse="True"
                             EasingFunction="{StaticResource Bounce}"/>
            <!-- Left arm waves (3 waves) -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftArmRotation" Storyboard.TargetProperty="Angle">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="-45"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="-20"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.55" Value="-50"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="-20"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.85" Value="-45"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.1" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Tilt body with wave -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="-10"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.55" Value="5"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.85" Value="-8"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.1" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Happy squish -->
            <DoubleAnimation Storyboard.TargetName="BodyScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.1" Duration="0:0:0.2" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="BodyScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.92" Duration="0:0:0.2" AutoReverse="True"/>
            <!-- Mouth opens -->
            <DoubleAnimation Storyboard.TargetName="MouthScale" Storyboard.TargetProperty="ScaleY"
                             From="0.3" To="1" Duration="0:0:0.2" AutoReverse="True"/>
        </Storyboard>

        <!-- ============ TALKING: bouncy + mouth flap ============ -->
        <Storyboard x:Key="TalkingAnimation" RepeatBehavior="3x">
            <DoubleAnimation Storyboard.TargetName="BodyPos" Storyboard.TargetProperty="Y"
                             From="0" To="-5" Duration="0:0:0.2" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <!-- Squash & stretch -->
            <DoubleAnimation Storyboard.TargetName="BodyScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.06" Duration="0:0:0.2" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="BodyScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.95" Duration="0:0:0.2" AutoReverse="True"/>
            <!-- Mouth flap -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MouthScale" Storyboard.TargetProperty="ScaleY">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.1" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.2" Value="0.3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.3" Value="0.8"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.4" Value="0.3"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Little hand gesture -->
            <DoubleAnimation Storyboard.TargetName="RightArmRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="-15" Duration="0:0:0.2" AutoReverse="True"/>
        </Storyboard>

        <!-- ============ POINTING: lean + arm point ============ -->
        <Storyboard x:Key="PointingAnimation">
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="-15" Duration="0:0:0.4" EasingFunction="{StaticResource Back}"/>
            <DoubleAnimation Storyboard.TargetName="BodyPos" Storyboard.TargetProperty="Y"
                             From="0" To="-6" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="LeftArmRotation" Storyboard.TargetProperty="Angle"
                             To="-60" Duration="0:0:0.4" EasingFunction="{StaticResource Back}"/>
            <!-- Eyes look where pointing -->
            <DoubleAnimation Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="X"
                             To="-3" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="X"
                             To="-3" Duration="0:0:0.3"/>
        </Storyboard>

        <!-- ============ CONFUSED: wobble + spiral eyes ============ -->
        <Storyboard x:Key="ConfusedAnimation" RepeatBehavior="2x">
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="-15" To="15" Duration="0:0:0.25" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
            <!-- Cross-eyed -->
            <DoubleAnimation Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="X"
                             From="0" To="3" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="X"
                             From="0" To="-3" Duration="0:0:0.15"/>
            <!-- Arms flail -->
            <DoubleAnimation Storyboard.TargetName="LeftArmRotation" Storyboard.TargetProperty="Angle"
                             From="10" To="-30" Duration="0:0:0.25" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="RightArmRotation" Storyboard.TargetProperty="Angle"
                             From="-10" To="30" Duration="0:0:0.25" AutoReverse="True"/>
            <!-- Mouth "oh" -->
            <DoubleAnimation Storyboard.TargetName="MouthScale" Storyboard.TargetProperty="ScaleY"
                             To="1.2" Duration="0:0:0.15"/>
        </Storyboard>

        <!-- ============ CELEBRATING: jump + spin + arms up ============ -->
        <Storyboard x:Key="CelebratingAnimation">
            <DoubleAnimation Storyboard.TargetName="BodyPos" Storyboard.TargetProperty="Y"
                             From="0" To="-30" Duration="0:0:0.4" AutoReverse="True"
                             EasingFunction="{StaticResource Bounce}"/>
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:0.7"/>
            <!-- Arms up! -->
            <DoubleAnimation Storyboard.TargetName="LeftArmRotation" Storyboard.TargetProperty="Angle"
                             To="-70" Duration="0:0:0.3" EasingFunction="{StaticResource Back}"/>
            <DoubleAnimation Storyboard.TargetName="RightArmRotation" Storyboard.TargetProperty="Angle"
                             To="70" Duration="0:0:0.3" EasingFunction="{StaticResource Back}"/>
            <!-- Big smile -->
            <DoubleAnimation Storyboard.TargetName="MouthScale" Storyboard.TargetProperty="ScaleY"
                             To="1.3" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="MouthScale" Storyboard.TargetProperty="ScaleX"
                             To="1.3" Duration="0:0:0.2"/>
            <!-- Sparkle flash -->
            <DoubleAnimation Storyboard.TargetName="Sparkle1" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" BeginTime="0:0:0.1" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Sparkle2" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" BeginTime="0:0:0.25" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="Sparkle3" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2" BeginTime="0:0:0.4" AutoReverse="True"/>
        </Storyboard>

        <!-- ============ LOOKING: eyes dart around alert ============ -->
        <Storyboard x:Key="LookingAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="X">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="4"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="-3"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:2.0" Value="-2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:2.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="X">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="4"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="-3"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:2.0" Value="-2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:2.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftPupilPos" Storyboard.TargetProperty="Y">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="-2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="-1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:2.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightPupilPos" Storyboard.TargetProperty="Y">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="-2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="-1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:2.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Slight head tilt following eyes -->
            <DoubleAnimation Storyboard.TargetName="BodyRotation" Storyboard.TargetProperty="Angle"
                             From="-3" To="3" Duration="0:0:1.25" AutoReverse="True"
                             EasingFunction="{StaticResource Sine}"/>
        </Storyboard>
    </UserControl.Resources>

    <Canvas x:Name="ClipsterCanvas" Width="120" Height="160">
        <!-- Sparkle effects (hidden until celebrating) -->
        <Path x:Name="Sparkle1" Canvas.Left="15" Canvas.Top="10" Opacity="0"
              Data="M 0,-6 L 2,-2 L 6,0 L 2,2 L 0,6 L -2,2 L -6,0 L -2,-2 Z"
              Fill="#FFFFD700" Stroke="#FFFFA500" StrokeThickness="0.5"/>
        <Path x:Name="Sparkle2" Canvas.Left="90" Canvas.Top="20" Opacity="0"
              Data="M 0,-5 L 1.5,-1.5 L 5,0 L 1.5,1.5 L 0,5 L -1.5,1.5 L -5,0 L -1.5,-1.5 Z"
              Fill="#FFFFD700" Stroke="#FFFFA500" StrokeThickness="0.5"/>
        <Path x:Name="Sparkle3" Canvas.Left="55" Canvas.Top="5" Opacity="0"
              Data="M 0,-4 L 1,-1 L 4,0 L 1,1 L 0,4 L -1,1 L -4,0 L -1,-1 Z"
              Fill="#FFFFFFFF" Stroke="#FFFFD700" StrokeThickness="0.5"/>

        <!-- Main body group -->
        <Canvas x:Name="ClipsterBody" Canvas.Left="15" Canvas.Top="15">
            <Canvas.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="BodyScale" ScaleX="1" ScaleY="1" CenterX="45" CenterY="60"/>
                    <RotateTransform x:Name="BodyRotation" Angle="0" CenterX="45" CenterY="60"/>
                    <TranslateTransform x:Name="BodyPos" X="0" Y="0"/>
                </TransformGroup>
            </Canvas.RenderTransform>

            <!-- Shadow -->
            <Ellipse x:Name="Shadow" Canvas.Left="12" Canvas.Top="120" Width="66" Height="12"
                     Opacity="0.18">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#60000000" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- LEFT ARM -->
            <Canvas Canvas.Left="2" Canvas.Top="55">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="LeftArmRotation" Angle="0" CenterX="14" CenterY="0"/>
                </Canvas.RenderTransform>
                <Path Stroke="#FF4488DD" StrokeThickness="4.5" Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 14,0 C 8,8 2,16 6,24"/>
                <!-- Hand -->
                <Ellipse Canvas.Left="2" Canvas.Top="21" Width="9" Height="9" Fill="#FF4488DD"/>
            </Canvas>

            <!-- RIGHT ARM -->
            <Canvas Canvas.Left="68" Canvas.Top="55">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="RightArmRotation" Angle="0" CenterX="0" CenterY="0"/>
                </Canvas.RenderTransform>
                <Path Stroke="#FF4488DD" StrokeThickness="4.5" Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 0,0 C 6,8 12,16 8,24"/>
                <Ellipse Canvas.Left="4" Canvas.Top="21" Width="9" Height="9" Fill="#FF4488DD"/>
            </Canvas>

            <!-- Paperclip body -->
            <Path StrokeThickness="6" Fill="Transparent"
                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 33,5 C 18,5 8,20 8,35 L 8,82 C 8,100 20,115 40,115 C 60,115 72,100 72,82 L 72,32 C 72,18 62,5 48,5 C 34,5 26,18 26,32 L 26,76 C 26,86 33,92 43,92 C 53,92 60,86 60,76 L 60,40">
                <Path.Stroke>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF7BB8F0" Offset="0"/>
                        <GradientStop Color="#FF4488DD" Offset="0.4"/>
                        <GradientStop Color="#FF2A6BC4" Offset="1"/>
                    </LinearGradientBrush>
                </Path.Stroke>
            </Path>

            <!-- Highlight/shine -->
            <Path Stroke="#60FFFFFF" StrokeThickness="3" Fill="Transparent"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 30,12 C 22,16 14,26 14,38 L 14,70"/>

            <!-- FACE AREA -->

            <!-- Left eye white -->
            <Ellipse Canvas.Left="24" Canvas.Top="36" Width="16" Height="18"
                     Fill="White" Stroke="#FF2A6BC4" StrokeThickness="1.8"/>
            <!-- Left pupil -->
            <Ellipse x:Name="LeftPupil" Canvas.Left="29" Canvas.Top="42" Width="7" Height="8" Fill="#FF0A0A1E">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="LeftEyeScale" ScaleX="1" ScaleY="1" CenterX="3.5" CenterY="4"/>
                        <TranslateTransform x:Name="LeftPupilPos" X="0" Y="0"/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>
            <!-- Left eye shine -->
            <Ellipse Canvas.Left="31" Canvas.Top="42" Width="3" Height="3" Fill="White" Opacity="0.9"/>

            <!-- Right eye white -->
            <Ellipse Canvas.Left="48" Canvas.Top="36" Width="16" Height="18"
                     Fill="White" Stroke="#FF2A6BC4" StrokeThickness="1.8"/>
            <!-- Right pupil -->
            <Ellipse x:Name="RightPupil" Canvas.Left="53" Canvas.Top="42" Width="7" Height="8" Fill="#FF0A0A1E">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="RightEyeScale" ScaleX="1" ScaleY="1" CenterX="3.5" CenterY="4"/>
                        <TranslateTransform x:Name="RightPupilPos" X="0" Y="0"/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>
            <!-- Right eye shine -->
            <Ellipse Canvas.Left="55" Canvas.Top="42" Width="3" Height="3" Fill="White" Opacity="0.9"/>

            <!-- Eyebrows -->
            <Path Stroke="#FF2A6BC4" StrokeThickness="2.8"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 24,34 Q 32,29 40,34">
                <Path.RenderTransform>
                    <TranslateTransform x:Name="LeftBrowPos" X="0" Y="0"/>
                </Path.RenderTransform>
            </Path>
            <Path Stroke="#FF2A6BC4" StrokeThickness="2.8"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 48,34 Q 56,29 64,34">
                <Path.RenderTransform>
                    <TranslateTransform x:Name="RightBrowPos" X="0" Y="0"/>
                </Path.RenderTransform>
            </Path>

            <!-- Mouth (smile arc) -->
            <Path Stroke="#FF2A6BC4" StrokeThickness="2.5" Fill="Transparent"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 34,62 Q 43,70 52,62">
                <Path.RenderTransform>
                    <ScaleTransform x:Name="MouthScale" ScaleX="1" ScaleY="0.3" CenterX="43" CenterY="66"/>
                </Path.RenderTransform>
            </Path>
        </Canvas>
    </Canvas>
</UserControl>
