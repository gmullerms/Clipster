<Window x:Class="Clipster.App.Views.QuickPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        Width="560" Height="80"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated"
        FocusManager.FocusedElement="{Binding ElementName=PromptInput}">

    <Border CornerRadius="14" Margin="10"
            BorderBrush="#FF3A3A5C" BorderThickness="1.5">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#F01E1E2E" Offset="0"/>
                <GradientStop Color="#F0252540" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Clipster icon -->
            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
                    Margin="4,0,8,0" VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF4472C4" Offset="0"/>
                        <GradientStop Color="#FF6B5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="&#x1F4CE;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Input -->
            <Grid Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Ask Clipster... (response copied to clipboard)"
                           FontSize="14" FontFamily="Segoe UI"
                           Foreground="#FF555566"
                           VerticalAlignment="Center" Margin="8,0"
                           IsHitTestVisible="False"
                           x:Name="PlaceholderText"/>
                <TextBox x:Name="PromptInput"
                         FontSize="14" FontFamily="Segoe UI"
                         Foreground="#FFE0E0F0"
                         CaretBrush="#FF6B5CE7"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="8,6"
                         VerticalContentAlignment="Center"
                         KeyDown="PromptInput_KeyDown"
                         TextChanged="PromptInput_TextChanged"/>
            </Grid>

            <!-- Submit hint -->
            <Border Grid.Column="2" CornerRadius="6" Padding="8,4" Margin="4,0"
                    Background="#FF2A2A40" VerticalAlignment="Center">
                <TextBlock x:Name="HintText" Text="Enter &#x21B5;" FontSize="11"
                           Foreground="#FF555566" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
