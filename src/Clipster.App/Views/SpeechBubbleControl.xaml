<UserControl x:Class="Clipster.App.Views.SpeechBubbleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MaxWidth="280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Bubble -->
        <Border Grid.Row="0"
                Background="#FFFFF8DC"
                BorderBrush="#FFD4A017"
                BorderThickness="2"
                CornerRadius="10"
                Padding="12,10"
                Effect="{StaticResource BubbleShadow}">
            <StackPanel>
                <TextBlock x:Name="BubbleText"
                           Text="Hello!"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Foreground="#FF333333"/>
                <ItemsControl x:Name="ActionButtons" Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Triangle pointer -->
        <Polygon Grid.Row="1"
                 Points="15,0 25,12 35,0"
                 Fill="#FFFFF8DC"
                 Stroke="#FFD4A017"
                 StrokeThickness="2"
                 Margin="10,-1,0,0"
                 HorizontalAlignment="Left"/>
    </Grid>
</UserControl>
