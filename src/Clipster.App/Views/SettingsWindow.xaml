<Window x:Class="Clipster.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Clipster.Core.Models;assembly=Clipster.Core"
        Title="Clipster Settings"
        Width="440" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="16" Background="#FF1E1E2E" Margin="10"
            BorderBrush="#FF3A3A5C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="16,12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF4472C4" Offset="0"/>
                        <GradientStop Color="#FF6B5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="&#x2699;&#xFE0F; Settings" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Configure your AI assistant" FontSize="10" Foreground="#B0FFFFFF"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2715;" FontSize="14"
                            Foreground="#B0FFFFFF" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="8,4" Click="CloseButton_Click"
                            VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Settings form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,8">
                <StackPanel>
                    <!-- API Key -->
                    <TextBlock Text="OpenAI API Key" FontSize="12" FontWeight="SemiBold"
                               Foreground="#FFB0B0C0" Margin="0,12,0,6"/>
                    <Border Background="#FF2A2A40" CornerRadius="8" BorderBrush="#FF3A3A5C" BorderThickness="1">
                        <PasswordBox x:Name="ApiKeyBox"
                                     Padding="10,8" FontSize="13"
                                     Foreground="#FFE0E0F0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    </Border>

                    <!-- Model -->
                    <TextBlock Text="Model" FontSize="12" FontWeight="SemiBold"
                               Foreground="#FFB0B0C0" Margin="0,16,0,6"/>
                    <Border Background="#FF2A2A40" CornerRadius="8" BorderBrush="#FF3A3A5C" BorderThickness="1">
                        <ComboBox SelectedValue="{Binding ModelName}" SelectedValuePath="Content"
                                  FontSize="13" Padding="10,8"
                                  Background="Transparent" Foreground="#FFE0E0F0"
                                  BorderThickness="0">
                            <ComboBoxItem Content="gpt-4o"/>
                            <ComboBoxItem Content="gpt-4o-mini"/>
                            <ComboBoxItem Content="gpt-4-turbo"/>
                            <ComboBoxItem Content="gpt-3.5-turbo"/>
                        </ComboBox>
                    </Border>

                    <!-- Character Style -->
                    <TextBlock Text="Character Style" FontSize="12" FontWeight="SemiBold"
                               Foreground="#FFB0B0C0" Margin="0,16,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content=" Classic"
                                     IsChecked="{Binding CharacterStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:CharacterStyle.Classic}}"
                                     Margin="0,0,20,0" FontSize="13" Foreground="#FFD0D0E0"/>
                        <RadioButton Content=" Modern"
                                     IsChecked="{Binding CharacterStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static models:CharacterStyle.Modern}}"
                                     FontSize="13" Foreground="#FFD0D0E0"/>
                    </StackPanel>

                    <!-- Feature toggles -->
                    <TextBlock Text="Features" FontSize="12" FontWeight="SemiBold"
                               Foreground="#FFB0B0C0" Margin="0,20,0,8"/>
                    <CheckBox Content=" Clipboard monitoring"
                              IsChecked="{Binding EnableClipboardMonitoring}"
                              Margin="0,6" FontSize="13" Foreground="#FFD0D0E0"/>
                    <CheckBox Content=" Proactive tips"
                              IsChecked="{Binding EnableProactiveTips}"
                              Margin="0,6" FontSize="13" Foreground="#FFD0D0E0"/>
                    <CheckBox Content=" Screen reading (OCR)"
                              IsChecked="{Binding EnableOcr}"
                              Margin="0,6" FontSize="13" Foreground="#FFD0D0E0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" CornerRadius="0,0,16,16" Background="#FF252538" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                               Foreground="#FF6B5CE7" VerticalAlignment="Center" FontSize="12"/>
                    <Button Grid.Column="1" Content="Save Settings" Command="{Binding SaveCommand}"
                            Cursor="Hand" Padding="20,8" FontSize="13" Foreground="White" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF4472C4" Offset="0"/>
                                            <GradientStop Color="#FF6B5CE7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
