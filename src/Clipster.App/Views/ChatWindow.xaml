<Window x:Class="Clipster.App.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Clipster.App.Converters"
        Title="Clipster Chat"
        Width="440" Height="600"
        MinWidth="360" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
    </Window.Resources>

    <!-- Outer border = the window frame with rounded corners + shadow -->
    <Border CornerRadius="16" Background="#FF1E1E2E" Margin="10"
            BorderBrush="#FF3A3A5C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header / Title bar (draggable) -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="16,12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF4472C4" Offset="0"/>
                        <GradientStop Color="#FF6B5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#30FFFFFF" Margin="0,0,10,0">
                            <TextBlock Text="&#x1F4CE;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Clipster" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#B0FFFFFF"/>
                                <TextBlock Text=" | " FontSize="10" Foreground="#50FFFFFF"
                                           Visibility="{Binding TokenInfo, Converter={StaticResource NonEmptyToVis}}"/>
                                <TextBlock Text="{Binding TokenInfo}" FontSize="10" Foreground="#70FFFFFF"
                                           Visibility="{Binding TokenInfo, Converter={StaticResource NonEmptyToVis}}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x2715;" FontSize="14"
                            Foreground="#B0FFFFFF" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="8,4" Click="CloseButton_Click"
                            VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#30FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Messages area -->
            <ScrollViewer Grid.Row="1" x:Name="MessageScroller"
                          VerticalScrollBarVisibility="Auto"
                          Background="#FF1E1E2E"
                          Padding="8,4">
                <ItemsControl x:Name="MessageList" ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6">
                                <Border MaxWidth="320" Padding="14,10" CornerRadius="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF2A2A40"/>
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="Margin" Value="8,0,50,0"/>
                                            <Setter Property="CornerRadius" Value="4,16,16,16"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="User">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="50,0,8,0"/>
                                                    <Setter Property="CornerRadius" Value="16,4,16,16"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF4472C4" Offset="0"/>
                                                                <GradientStop Color="#FF5B6FD6" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   FontSize="13" FontFamily="Segoe UI" LineHeight="20">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFD0D0E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="User">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="9" Margin="0,4,0,0" Opacity="0.4"
                                                   Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF888899"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="User">
                                                            <Setter Property="Foreground" Value="#BBFFFFFF"/>
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Thinking indicator -->
            <Border Grid.Row="2" Padding="16,8" Background="#FF1E1E2E"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <!-- Animated dots -->
                    <Border Width="8" Height="8" CornerRadius="4" Background="#FF6B5CE7" Margin="0,0,4,0">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.6" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Width="8" Height="8" CornerRadius="4" Background="#FF6B5CE7" Margin="0,0,4,0">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.6" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Width="8" Height="8" CornerRadius="4" Background="#FF6B5CE7" Margin="0,0,8,0">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.6" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#FF888899"
                               FontStyle="Italic" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Input area -->
            <Border Grid.Row="3" Background="#FF252538" CornerRadius="0,0,16,16" Padding="12,10">
                <StackPanel>
                    <!-- Quick actions row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding CanAnalyzeScreen, Converter={StaticResource BoolToVis}}">
                        <Button Content="&#x1F441;&#xFE0F; Screen"
                                Command="{Binding AnalyzeScreenCommand}"
                                Cursor="Hand" Padding="10,5" FontSize="11"
                                Foreground="#FFB0B0C0" Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#FF2A2A40" CornerRadius="10"
                                            BorderBrush="#FF3A3A5C" BorderThickness="1" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF3A3A55"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B5CE7"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Text input + send -->
                    <Border Background="#FF2A2A40" CornerRadius="12"
                            BorderBrush="#FF3A3A5C" BorderThickness="1"
                            Padding="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Input with placeholder -->
                            <Grid Grid.Column="0">
                                <TextBlock Text="Ask Clipster anything..."
                                           FontSize="13" FontFamily="Segoe UI"
                                           Foreground="#FF555566"
                                           VerticalAlignment="Center" Margin="10,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UserInput}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding UserInput}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="InputBox"
                                         Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" FontFamily="Segoe UI"
                                         Foreground="#FFE0E0F0"
                                         CaretBrush="#FF6B5CE7"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="10,8"
                                         VerticalContentAlignment="Center"
                                         KeyDown="InputBox_KeyDown"
                                         AcceptsReturn="False"/>
                            </Grid>

                            <!-- Send button -->
                            <Button Grid.Column="1" Command="{Binding SendCommand}"
                                    Cursor="Hand" Margin="4" Width="36" Height="36">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SendBd" CornerRadius="10" Padding="6">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF4472C4" Offset="0"/>
                                                    <GradientStop Color="#FF6B5CE7" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <!-- Arrow icon -->
                                            <Path Data="M 4,10 L 12,4 L 12,7 L 20,7 L 20,13 L 12,13 L 12,16 Z"
                                                  Fill="White" Stretch="Uniform"
                                                  Width="16" Height="16"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SendBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="SendBd" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
