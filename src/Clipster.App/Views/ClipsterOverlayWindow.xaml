<Window x:Class="Clipster.App.Views.ClipsterOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Clipster.App.Views"
        xmlns:controls="clr-namespace:Clipster.App.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Speech Bubble -->
        <views:SpeechBubbleControl x:Name="SpeechBubble"
                                   Grid.Row="0"
                                   Margin="0,0,0,5"
                                   Visibility="Collapsed"/>

        <!-- Clipster Character -->
        <Grid Grid.Row="1" x:Name="CharacterHost"
              Cursor="Hand"
              MouseLeftButtonDown="Clipster_MouseLeftButtonDown">

            <!-- Modern vector Clipster -->
            <controls:VectorClipsterControl x:Name="VectorClipster" Visibility="Visible"/>

            <!-- Classic retro Clipster -->
            <controls:ClassicClipsterControl x:Name="ClassicClipster" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
